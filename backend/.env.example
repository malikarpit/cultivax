# Database
DATABASE_URL=postgresql://cultivax_user:cultivax_pass@localhost:5432/cultivax_db

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_NAME=CultivaX
APP_ENV=development
DEBUG=true

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Redis (for distributed rate limiting)
REDIS_URL=redis://localhost:6379/0

# Admin API Key (generate using: python -c "import secrets; print(f'cultivax_admin_{secrets.token_urlsafe(32)}')")
ADMIN_API_KEY=

# Production Security
PROD_DB_HOST_ALLOWLIST=

# Weather API (Phase 2)
# WEATHER_API_KEY=your-openweathermap-key
# WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# Cloud Storage (Phase 4)
# GCS_BUCKET_NAME=cultivax-media
# GCS_PROJECT_ID=your-gcp-project-id

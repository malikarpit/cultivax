# ============================================================
# CultivaX — Environment Template
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The app works out of the box WITHOUT any keys below.
# They are only needed for real SMS and live weather data.
# ============================================================

# OpenWeatherMap API key (OPTIONAL — falls back to Open-Meteo for free weather)
# Get yours free at: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# SMS Provider (OPTIONAL — defaults to 'stub' which logs OTPs to the console)
# Set to 'twilio' and fill in credentials below to send real SMS
SMS_PROVIDER=stub

# Twilio credentials (only needed if SMS_PROVIDER=twilio)
# Sign up at: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
